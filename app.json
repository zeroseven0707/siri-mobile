{
  "expo": {
    "name": "Siri",
    "slug": "siri-mobile",
    "version": "1.0.0",
    "orientation": "portrait",
    "scheme": "siri",
    "userInterfaceStyle": "light",
    "icon": "./assets/images/icon.png",
    "splash": {
      "image": "./assets/images/siri.png",
      "resizeMode": "contain",
      "backgroundColor": "#ffffff"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "id.siri.mobile"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/icon.png",
        "backgroundColor": "#ffffff"
      },
      "package": "si.ri",
      "googleServicesFile": "./google-services.json",
      "softwareKeyboardLayoutMode": "pan"
    },
    "plugins": [
      "expo-router",
      "expo-secure-store",
      "expo-asset",
      [
        "expo-location",
        {
          "locationAlwaysAndWhenInUsePermission": "Izinkan Siri mengakses lokasi Anda agar driver dapat menjemput Anda dengan tepat."
        }
      ],
      "@react-native-firebase/app",
      "@react-native-firebase/messaging",
      "@notifee/react-native",
      [
        "expo-build-properties",
        {
          "android": {
            "extraMavenRepo": "https://maven.google.com"
          }
        }
      ]
    ],
    "extra": {
      "router": {},
      "eas": {
        "projectId": "68ea0c1b-bbf1-4ca0-a59b-53fa812ff333"
      }
    }
  }
}
